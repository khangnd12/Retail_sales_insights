# Virtual environment
.venv/

# Python-generated files
__pycache__/
*.py[cod]

# Jupyter temporary files
.ipynb_checkpoints/

# Environment variables and secrets
.env

# VS Code local configuration
.vscode/

# Operating-system files
.DS_Store
Thumbs.db

# Raw and generated data
data/raw/*
data/processed/*

# Preserve empty folder placeholders
!data/raw/.gitkeep
!data/processed/.gitkeep